{
  "name": "echovault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A music visualizer and media multi-analyzer that records a compact spectral history of what you listen to.",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host --mode lan",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android && cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1"
  }
}
